{
  "name": "iptv-player",
  "version": "1.0.0",
  "description": "IPTV Player for Linux",
  "main": "src/main.js",
  "author": "Ke619",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --linux AppImage"
  },
  "build": {
    "appId": "com.iptv.player",
    "productName": "IPTV Player",
    "files": [
      "src/**/*"
    ],
    "linux": {
      "target": "AppImage",
      "category": "AudioVideo"
    }
  },
  "devDependencies": {
    "electron": "^36.0.0",
    "electron-builder": "^26.0.0"
  }
}
